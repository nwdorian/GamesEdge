{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
   "tasks": [{
        "name": "Run csharpier",
        "command": "dotnet",
        "args": [ "csharpier", "format", "." ],
        "include": [
            "**/*.cs",
            "**/*.csx",
            "**/*.csproj",
            "**/*.props",
            "**/*.targets",
            "**/*.xml",
            "**/*.config"
        ]
    }]
}
